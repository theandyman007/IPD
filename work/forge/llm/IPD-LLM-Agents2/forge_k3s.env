# Environment variables for bare-metal access to K3s containers
#
# Purpose:  setup environment variables recognized by Containerized Architecture
# Usage:    source forge_k3s.env

export FORGE_DB_HOST=platinum     # PostgreSQL host (forgedb.py)
export FORGE_CONN_DB_PORT=30432   # PostgreSQL port (forgedb.py) - default 5432, K3s NodePort 30432
export FORGE_DB_USER=postgres     # Allows researcher to use database
export OLLAMA_HOST=tungsten       # Ollama host fallback (ollama_agent.py)
export OLLAMA_HOST_0=tungsten     # Ollama hosts per agent (config.py, episodic_ipd_game.py)
export OLLAMA_HOST_1=tungsten     # Ollama hosts per agent (config.py, episodic_ipd_game.py)
export OLLAMA_PORT=12434          # Ollama port (ollama_agent.py) - default 11434, K3s hostPort 12434