# Environment variables for bare-metal access to K3s containers
# - FORGE_DB_HOST:    PostgreSQL host (forgedb.py)
# - FORGE_DB_PORT:    PostgreSQL port (forgedb.py) - default 5432, K3s NodePort 30432
# - OLLAMA_HOST:      Ollama host fallback (ollama_agent.py)
# - OLLAMA_HOST_0/1:  Ollama hosts per agent (config.py, episodic_ipd_game.py)
# - OLLAMA_PORT:      Ollama port (ollama_agent.py) - default 11434, K3s hostPort 12434
#
# Usage: source forge_k3s.env

export FORGE_DB_HOST=platinum
export FORGE_DB_PORT=30432
export OLLAMA_HOST=tungsten
export OLLAMA_HOST_0=tungsten
export OLLAMA_HOST_1=tungsten
export OLLAMA_PORT=12434